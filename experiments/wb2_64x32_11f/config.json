{
  "batch_size": 1,
  "learning_rate": 1e-3,
  "num_epochs": 30,
  "wandb_log": false,
  "random_seed": 42,
  "graph": {
    "grid2mesh_edge_creation": "radius",
    "mesh2grid_edge_creation": "contained",
    "grid2mesh_radius_query": 0.5,
    "mesh_levels": [3, 5]
  },
  "pipeline": {
    "encoder": {
      "mlp": { "mlp_hidden_dims": [64, 64], "output_dim": 64, "use_layer_norm": false },
      "graph": { "layer_type": "conv_gcn", "hidden_dims": [128, 128], "output_dim": 128 }
    },
    "processor": {
      "mlp":   { "mlp_hidden_dims": [128], "output_dim": 128, "use_layer_norm": false },
      "graph": { "layer_type": "conv_gcn", "hidden_dims": [128, 128], "output_dim": 128 }
    },
    "decoder": {
      "mlp":   { "mlp_hidden_dims": [128], "output_dim": 128, "use_layer_norm": false },
      "graph": { "layer_type": "conv_gcn", "hidden_dims": [64, 64], "output_dim": 11 }
    }
  },
  "data": {
    "dataset_name": "wb2_64x32_11f_2obs_1pred",
    "num_features_used": 11,
    "obs_window_used": 2,
    "pred_window_used": 1,
    "want_feats_flattened": true
  }
}
